# 🌿 Herbute Backend — Configuration
PORT=2065
NODE_ENV=development

# 🗄️ Database
MONGODB_URI=mongodb://localhost:27017/herbute

# 🔑 JWT RS256
# Note: Si vides, le backend cherchera ./keys/private.pem et ./keys/public.pem
JWT_PRIVATE_KEY=""
JWT_PUBLIC_KEY=""
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_ISSUER=herbute.ma
JWT_AUDIENCE=herbute-app

# 🌐 CORS & Security
# Liste séparée par des virgules
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
INTROSPECT_ALLOWED_IPS=127.0.0.1,::1

# 📧 Email (Nodemailer)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@herbute.ma

# ☁️ Cloud & Services (Optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
