#!/bin/bash

# ============================================================
#   SETUP ENVIRONNEMENT DE TEST COMPLET POUR VSCODE
#   Compatible: Ubuntu / Debian / WSL / macOS (partiel)
# ============================================================

set -e

BOLD="\033[1m"
GREEN="\033[0;32m"
BLUE="\033[0;34m"
YELLOW="\033[1;33m"
RED="\033[0;31m"
RESET="\033[0m"

log()    { echo -e "${GREEN}[✔]${RESET} $1"; }
info()   { echo -e "${BLUE}[i]${RESET} $1"; }
warn()   { echo -e "${YELLOW}[!]${RESET} $1"; }
error()  { echo -e "${RED}[✘]${RESET} $1"; exit 1; }
title()  { echo -e "\n${BOLD}${BLUE}══════════════════════════════════════${RESET}"; echo -e "${BOLD}  $1${RESET}"; echo -e "${BOLD}${BLUE}══════════════════════════════════════${RESET}\n"; }

# ─────────────────────────────────────────
# 0. VÉRIFICATIONS INITIALES
# ─────────────────────────────────────────
title "0. Vérifications initiales"

if ! command -v node &>/dev/null; then
  warn "Node.js non trouvé. Installation via nvm..."
  curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.7/install.sh | bash
  export NVM_DIR="$HOME/.nvm"
  [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
  nvm install --lts
  nvm use --lts
  log "Node.js LTS installé : $(node -v)"
else
  log "Node.js détecté : $(node -v)"
fi

if ! command -v python3 &>/dev/null; then
  warn "Python3 non trouvé. Installation..."
  sudo apt-get update -qq && sudo apt-get install -y python3 python3-pip
fi
log "Python3 détecté : $(python3 --version)"

if ! command -v git &>/dev/null; then
  sudo apt-get install -y git
fi
log "Git détecté : $(git --version)"

# ─────────────────────────────────────────
# 1. OUTILS DE TEST DE BASE
# ─────────────────────────────────────────
title "1. Outils de test de base"

info "Installation des outils globaux npm..."
npm install -g \
  jest \
  vitest \
  mocha \
  chai \
  supertest \
  ts-jest \
  @jest/globals \
  nodemon \
  2>/dev/null

log "Jest        → test unitaire JS/TS"
log "Vitest      → test rapide (Vite ecosystem)"
log "Mocha+Chai  → test BDD flexible"
log "Supertest   → test API HTTP"
log "Nodemon     → rechargement automatique"

# ─────────────────────────────────────────
# 2. FLUX FRONT-END AUTOMATISÉS
# ─────────────────────────────────────────
title "2. Flux automatisés Front-end"

npm install -g \
  @playwright/test \
  cypress \
  @testing-library/dom \
  @testing-library/jest-dom \
  2>/dev/null

# Playwright browsers
info "Installation des navigateurs Playwright..."
npx playwright install --with-deps chromium firefox webkit 2>/dev/null || warn "Playwright browsers partiellement installés"

log "Playwright  → E2E multi-navigateur"
log "Cypress     → E2E visuel interactif"
log "Testing Lib → test composants React/Vue"

# ─────────────────────────────────────────
# 3. FLUX BACK-END AUTOMATISÉS
# ─────────────────────────────────────────
title "3. Flux automatisés Back-end"

npm install -g \
  autocannon \
  artillery \
  newman \
  2>/dev/null

pip3 install pytest pytest-asyncio httpx locust --break-system-packages 2>/dev/null || \
  pip3 install pytest pytest-asyncio httpx locust 2>/dev/null

log "Autocannon  → benchmark HTTP rapide"
log "Artillery   → test de charge avancé"
log "Newman      → exécution Postman en CLI"
log "Pytest      → test Python"
log "Locust      → test de charge Python (UI web)"

# ─────────────────────────────────────────
# 4. FONCTIONNALITÉS DE TEST AVANCÉES
# ─────────────────────────────────────────
title "4. Fonctionnalités avancées"

npm install -g \
  @stryker-mutator/core \
  @stryker-mutator/jest-runner \
  nock \
  sinon \
  faker \
  msw \
  2>/dev/null

pip3 install hypothesis coverage pytest-cov --break-system-packages 2>/dev/null || \
  pip3 install hypothesis coverage pytest-cov 2>/dev/null

log "Stryker     → mutation testing (détecte les tests faibles)"
log "Nock/MSW    → mock HTTP / Service Worker mock"
log "Sinon       → spies, stubs, mocks"
log "Faker       → génération de données de test"
log "Hypothesis  → property-based testing Python"
log "pytest-cov  → couverture de code Python"

# ─────────────────────────────────────────
# 5. GÉNÉRATION DE TESTS AMÉLIORÉE
# ─────────────────────────────────────────
title "5. Génération de tests (IA + couverture)"

npm install -g \
  nyc \
  c8 \
  istanbul \
  2>/dev/null

# Extensions VSCode recommandées (liste exportable)
VSCODE_EXTENSIONS=(
  "ms-vscode.vscode-jest"
  "orta.vscode-jest"
  "ms-playwright.playwright"
  "Cypress.cypress-snippets"
  "ryanluker.vscode-coverage-gutters"
  "hbenl.vscode-test-explorer"
  "formulahendry.code-runner"
  "streetsidesoftware.code-spell-checker"
  "GitHub.copilot"
  "GitHub.copilot-chat"
  "eamodio.gitlens"
  "dbaeumer.vscode-eslint"
  "esbenp.prettier-vscode"
  "christian-kohler.path-intellisense"
)

info "Installation des extensions VSCode..."
for ext in "${VSCODE_EXTENSIONS[@]}"; do
  code --install-extension "$ext" --force 2>/dev/null && log "Extension: $ext" || warn "Skip: $ext (VSCode non dispo en CLI)"
done

log "NYC/C8/Istanbul → couverture de code JS"

# ─────────────────────────────────────────
# 6. CONFIGURATIONS PERSONNALISÉES
# ─────────────────────────────────────────
title "6. Création des fichiers de configuration"

PROJECT_DIR="$HOME/test-workspace"
mkdir -p "$PROJECT_DIR"
cd "$PROJECT_DIR"

# ── jest.config.js ──────────────────────
cat > jest.config.js << 'EOF'
/** @type {import('jest').Config} */
module.exports = {
  testEnvironment: 'node',
  coverageThreshold: {
    global: {
      branches: 80,
      functions: 80,
      lines: 80,
      statements: 80,
    },
  },
  collectCoverageFrom: [
    'src/**/*.{js,ts}',
    '!src/**/*.d.ts',
    '!src/**/index.ts',
  ],
  coverageReporters: ['text', 'lcov', 'html'],
  testMatch: [
    '**/__tests__/**/*.[jt]s?(x)',
    '**/?(*.)+(spec|test).[jt]s?(x)',
  ],
  transform: {
    '^.+\\.tsx?$': 'ts-jest',
  },
  verbose: true,
  testTimeout: 10000,
};
EOF
log "jest.config.js créé"

# ── vitest.config.ts ─────────────────────
cat > vitest.config.ts << 'EOF'
import { defineConfig } from 'vitest/config';

export default defineConfig({
  test: {
    globals: true,
    environment: 'jsdom',
    coverage: {
      provider: 'v8',
      reporter: ['text', 'html', 'lcov'],
      thresholds: { lines: 80, functions: 80, branches: 80 },
    },
    reporters: ['verbose'],
    testTimeout: 10000,
  },
});
EOF
log "vitest.config.ts créé"

# ── playwright.config.ts ─────────────────
cat > playwright.config.ts << 'EOF'
import { defineConfig, devices } from '@playwright/test';

export default defineConfig({
  testDir: './e2e',
  fullyParallel: true,
  forbidOnly: !!process.env.CI,
  retries: process.env.CI ? 2 : 0,
  workers: process.env.CI ? 1 : undefined,
  reporter: [['html', { open: 'never' }], ['list']],
  use: {
    baseURL: 'http://localhost:3000',
    trace: 'on-first-retry',
    screenshot: 'only-on-failure',
    video: 'retain-on-failure',
  },
  projects: [
    { name: 'chromium', use: { ...devices['Desktop Chrome'] } },
    { name: 'firefox',  use: { ...devices['Desktop Firefox'] } },
    { name: 'webkit',   use: { ...devices['Desktop Safari'] } },
    { name: 'mobile',   use: { ...devices['iPhone 14'] } },
  ],
  webServer: {
    command: 'npm run dev',
    url: 'http://localhost:3000',
    reuseExistingServer: !process.env.CI,
  },
});
EOF
log "playwright.config.ts créé"

# ── .nycrc (couverture Istanbul) ──────────
cat > .nycrc << 'EOF'
{
  "extends": "@istanbuljs/schema",
  "all": true,
  "include": ["src/**/*.js"],
  "exclude": ["**/*.spec.js", "**/*.test.js", "node_modules"],
  "reporter": ["text", "html", "lcov"],
  "branches": 80,
  "lines": 80,
  "functions": 80,
  "statements": 80,
  "check-coverage": true
}
EOF
log ".nycrc créé"

# ── pytest.ini ────────────────────────────
cat > pytest.ini << 'EOF'
[pytest]
testpaths = tests
python_files = test_*.py *_test.py
python_classes = Test*
python_functions = test_*
addopts =
  -v
  --tb=short
  --cov=src
  --cov-report=term-missing
  --cov-report=html:coverage_html
  --cov-fail-under=80
asyncio_mode = auto
EOF
log "pytest.ini créé"

# ── artillery.yml (test de charge) ───────
cat > artillery.yml << 'EOF'
config:
  target: "http://localhost:3000"
  phases:
    - duration: 60
      arrivalRate: 10
      name: "Montée en charge"
    - duration: 120
      arrivalRate: 50
      name: "Charge nominale"
    - duration: 60
      arrivalRate: 100
      name: "Pic de charge"
  defaults:
    headers:
      Content-Type: "application/json"

scenarios:
  - name: "Test API principal"
    flow:
      - get:
          url: "/api/health"
          expect:
            - statusCode: 200
      - post:
          url: "/api/test"
          json:
            data: "test"
          expect:
            - statusCode: 201
EOF
log "artillery.yml créé"

# ── .vscode/settings.json ─────────────────
mkdir -p .vscode
cat > .vscode/settings.json << 'EOF'
{
  "jest.autoRun": {
    "watch": true,
    "onStartup": ["all-tests"]
  },
  "jest.showCoverageOnLoad": true,
  "coverage-gutters.showLineCoverage": true,
  "coverage-gutters.showRulerCoverage": true,
  "coverage-gutters.coverageFileNames": [
    "lcov.info",
    "coverage/lcov.info",
    "coverage_html/lcov.info"
  ],
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "testing.automaticallyOpenPeekView": "failureInVisibleDocument",
  "playwright.reuseBrowser": false,
  "playwright.showTrace": true,
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": ["tests"],
  "python.testing.unittestEnabled": false
}
EOF
log ".vscode/settings.json créé"

# ── .vscode/launch.json (debug) ───────────
cat > .vscode/launch.json << 'EOF'
{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "▶ Jest: Fichier courant",
      "program": "${workspaceFolder}/node_modules/.bin/jest",
      "args": ["${fileBasenameNoExtension}", "--no-coverage"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "▶ Jest: Tous les tests",
      "program": "${workspaceFolder}/node_modules/.bin/jest",
      "args": ["--coverage"],
      "console": "integratedTerminal"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "▶ Vitest: Fichier courant",
      "program": "${workspaceFolder}/node_modules/.bin/vitest",
      "args": ["run", "${fileBasenameNoExtension}"],
      "console": "integratedTerminal"
    },
    {
      "type": "python",
      "request": "launch",
      "name": "▶ Pytest: Fichier courant",
      "module": "pytest",
      "args": ["${file}", "-v"],
      "console": "integratedTerminal"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "▶ Playwright: E2E",
      "program": "${workspaceFolder}/node_modules/.bin/playwright",
      "args": ["test", "--headed"],
      "console": "integratedTerminal"
    }
  ]
}
EOF
log ".vscode/launch.json créé"

# ── .vscode/tasks.json (tâches automatisées) ─
cat > .vscode/tasks.json << 'EOF'
{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🧪 Jest: Watch mode",
      "type": "shell",
      "command": "npx jest --watch",
      "group": "test",
      "presentation": { "panel": "dedicated", "reveal": "always" }
    },
    {
      "label": "🧪 Vitest: Watch mode",
      "type": "shell",
      "command": "npx vitest",
      "group": "test",
      "presentation": { "panel": "dedicated" }
    },
    {
      "label": "📊 Coverage: Jest",
      "type": "shell",
      "command": "npx jest --coverage --coverageReporters=html && echo 'Rapport: coverage/index.html'",
      "group": "test"
    },
    {
      "label": "🎭 Playwright: Run all E2E",
      "type": "shell",
      "command": "npx playwright test",
      "group": "test"
    },
    {
      "label": "🎭 Playwright: UI Mode",
      "type": "shell",
      "command": "npx playwright test --ui",
      "group": "test"
    },
    {
      "label": "🐍 Pytest: All tests",
      "type": "shell",
      "command": "python3 -m pytest -v",
      "group": "test"
    },
    {
      "label": "🔫 Stryker: Mutation tests",
      "type": "shell",
      "command": "npx stryker run",
      "group": "test"
    },
    {
      "label": "🚀 Artillery: Load test",
      "type": "shell",
      "command": "npx artillery run artillery.yml --output report.json && npx artillery report report.json",
      "group": "test"
    },
    {
      "label": "⚡ Autocannon: Quick benchmark",
      "type": "shell",
      "command": "npx autocannon -c 100 -d 30 http://localhost:3000",
      "group": "test"
    },
    {
      "label": "🔍 ESLint: Fix all",
      "type": "shell",
      "command": "npx eslint . --fix",
      "group": "build"
    }
  ]
}
EOF
log ".vscode/tasks.json créé"

# ── package.json (scripts npm) ────────────
cat > package.json << 'EOF'
{
  "name": "test-workspace",
  "version": "1.0.0",
  "description": "Environnement de test complet VSCode",
  "scripts": {
    "test":              "jest",
    "test:watch":        "jest --watch",
    "test:coverage":     "jest --coverage",
    "test:vitest":       "vitest run",
    "test:vitest:watch": "vitest",
    "test:e2e":          "playwright test",
    "test:e2e:ui":       "playwright test --ui",
    "test:e2e:headed":   "playwright test --headed",
    "test:mutation":     "stryker run",
    "test:load":         "artillery run artillery.yml",
    "test:bench":        "autocannon -c 100 -d 30 http://localhost:3000",
    "test:all":          "npm run test:coverage && npm run test:e2e",
    "test:ci":           "jest --ci --coverage && playwright test",
    "coverage:open":     "open coverage/index.html || xdg-open coverage/index.html",
    "lint":              "eslint . --ext .js,.ts,.jsx,.tsx",
    "lint:fix":          "eslint . --ext .js,.ts,.jsx,.tsx --fix"
  },
  "devDependencies": {}
}
EOF
log "package.json créé"

# ─────────────────────────────────────────
# 7. OPTIMISATION DE L'EXÉCUTION
# ─────────────────────────────────────────
title "7. Optimisation de l'exécution"

# Jest avec cache + workers optimisés
cat >> jest.config.js << 'EOF'

// ── Optimisation ──────────────────────────
// maxWorkers: utilise tous les cœurs CPU
// cache: évite de recompiler les fichiers inchangés
module.exports.maxWorkers = '50%';
module.exports.cache = true;
module.exports.cacheDirectory = '/tmp/jest-cache';
EOF

# .env pour CI/CD
cat > .env.test << 'EOF'
NODE_ENV=test
CI=false
TEST_TIMEOUT=10000
COVERAGE_THRESHOLD=80
BASE_URL=http://localhost:3000
EOF
log ".env.test créé (variables d'environnement test)"

log "Optimisations Jest activées (cache + workers parallèles)"

# ─────────────────────────────────────────
# 8. STRUCTURE DE PROJET EXEMPLE
# ─────────────────────────────────────────
title "8. Création de la structure de projet"

mkdir -p src tests/__tests__ tests/integration e2e

# Exemple de fonction à tester
cat > src/calculator.js << 'EOF'
/** Fonctions utilitaires — à tester */
const add      = (a, b) => a + b;
const subtract = (a, b) => a - b;
const multiply = (a, b) => a * b;
const divide   = (a, b) => { if (b === 0) throw new Error('Division par zéro'); return a / b; };

module.exports = { add, subtract, multiply, divide };
EOF

# Test unitaire Jest
cat > tests/__tests__/calculator.test.js << 'EOF'
const { add, subtract, multiply, divide } = require('../../src/calculator');

describe('Calculator', () => {
  test('add: 2 + 3 = 5',           () => expect(add(2, 3)).toBe(5));
  test('subtract: 5 - 3 = 2',      () => expect(subtract(5, 3)).toBe(2));
  test('multiply: 4 * 3 = 12',     () => expect(multiply(4, 3)).toBe(12));
  test('divide: 10 / 2 = 5',       () => expect(divide(10, 2)).toBe(5));
  test('divide: par zéro → erreur',() => expect(() => divide(5, 0)).toThrow('Division par zéro'));
});
EOF

# Test E2E Playwright
cat > e2e/home.spec.ts << 'EOF'
import { test, expect } from '@playwright/test';

test.describe('Page principale', () => {
  test('a le bon titre', async ({ page }) => {
    await page.goto('/');
    await expect(page).toHaveTitle(/.*/, { timeout: 5000 });
  });

  test('répond en moins de 2s', async ({ page }) => {
    const start = Date.now();
    await page.goto('/');
    expect(Date.now() - start).toBeLessThan(2000);
  });
});
EOF

# Test Python exemple
mkdir -p tests/python
cat > tests/python/test_example.py << 'EOF'
import pytest

def add(a, b):
    return a + b

class TestCalculator:
    def test_addition(self):
        assert add(2, 3) == 5

    def test_addition_negative(self):
        assert add(-1, 1) == 0

    @pytest.mark.parametrize("a,b,expected", [
        (1, 2, 3),
        (0, 0, 0),
        (-1, -1, -2),
    ])
    def test_addition_parametric(self, a, b, expected):
        assert add(a, b) == expected
EOF

log "Structure créée : src/, tests/, e2e/"
log "Exemples de tests générés (Jest + Playwright + Pytest)"

# ─────────────────────────────────────────
# 9. RÉCAPITULATIF FINAL
# ─────────────────────────────────────────
title "✅ Installation terminée"

echo -e "${BOLD}📁 Workspace : ${GREEN}$PROJECT_DIR${RESET}"
echo ""
echo -e "${BOLD}Commandes rapides :${RESET}"
echo -e "  ${GREEN}npm test${RESET}                  → Tests unitaires Jest"
echo -e "  ${GREEN}npm run test:watch${RESET}        → Mode watch (relance auto)"
echo -e "  ${GREEN}npm run test:coverage${RESET}     → Rapport de couverture"
echo -e "  ${GREEN}npm run test:vitest${RESET}       → Tests avec Vitest"
echo -e "  ${GREEN}npm run test:e2e${RESET}          → Tests E2E Playwright"
echo -e "  ${GREEN}npm run test:e2e:ui${RESET}       → Playwright en mode UI"
echo -e "  ${GREEN}npm run test:load${RESET}         → Test de charge Artillery"
echo -e "  ${GREEN}npm run test:mutation${RESET}     → Tests de mutation Stryker"
echo -e "  ${GREEN}python3 -m pytest -v${RESET}      → Tests Python"
echo ""
echo -e "${BOLD}Dans VSCode :${RESET}"
echo -e "  ${YELLOW}Ctrl+Shift+P${RESET} → 'Tasks: Run Task' → choisir un test"
echo -e "  ${YELLOW}F5${RESET}            → Lancer la config debug active"
echo -e "  ${YELLOW}Ctrl+Shift+\`${RESET} → Terminal intégré"
echo ""
echo -e "${GREEN}${BOLD}Environnement prêt ! Ouvre VSCode dans : code $PROJECT_DIR${RESET}"
